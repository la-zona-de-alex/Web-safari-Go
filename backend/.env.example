# Ejemplo de variables de entorno para backend
# Copia este archivo a .env y reemplaza los valores reales

# Cadena de conexión MSSQL (ADO.NET style)
# Ejemplo local con Docker Compose: Server=mssql,1433;Initial Catalog=WebSafari;User Id=sa;Password=Your_password123;Encrypt=false;TrustServerCertificate=true;
MSSQL_CONN=

# Alternativa: DB_DRIVER_CONN (usado igual que MSSQL_CONN en el código)
DB_DRIVER_CONN=

JWT_SECRET=change-me
FRONTEND_ORIGIN=http://localhost:5173
PORT=4000
